{
  "expo": {
    "name": "AI ProfilePicture",
    "slug": "ai-profilepicture",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nanoportrait.aiprofilepicture",
      "infoPlist": {
        "NSCameraUsageDescription": "AI ProfilePicture uses the camera so you can capture a portrait for AI styling.",
        "NSPhotoLibraryUsageDescription": "AI ProfilePicture accesses your photo library so you can choose a portrait to transform.",
        "NSPhotoLibraryAddUsageDescription": "AI ProfilePicture saves generated portraits to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
